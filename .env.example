# Application
APP_ENV=development
ASSISTANT_NAME=پاسخ‌یار
COMPANY_NAME=نام شرکت
# Optional public support channels. Leave empty to hide and omit them from fallbacks.
SUPPORT_EMAIL=
SUPPORT_PHONE=
SUPPORT_URL=
DATA_DIR=app/data/runtime
SQLITE_PATH=app/data/runtime/rag.sqlite3
CHROMA_PERSIST_DIR=app/data/runtime/chroma
CHROMA_COLLECTION_NAME=customer_support_multilingual_minilm_normalized_paragraph_v2

# GapGPT chat (OpenAI-compatible)
CHAT_PROVIDER=gapgpt
CHAT_MODEL=gpt-4o
CHAT_BASE_URL=https://api.gapgpt.app/v1
CHAT_API_KEY=YOUR_GAPGPT_API_KEY

# Local multilingual embeddings — no API key and no Ollama required
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BATCH_SIZE=64

# RAG
TOP_K=4
RETRIEVAL_MAX_DISTANCE=0.65
CHUNK_SIZE=900
CHUNK_OVERLAP=150
MAX_HISTORY_MESSAGES=12
GENERATION_STALE_AFTER_SECONDS=600
MAX_MESSAGE_CHARS=4000

# Admin, widget identity, and browser access
ADMIN_API_KEY=change-this-long-random-key
SERVER_CONVERSATIONS_ENABLED=true
# Use a different high-entropy secret in every environment. The host website signs short-lived widget tokens with it.
WIDGET_TOKEN_SECRET=change-this-widget-signing-secret
WIDGET_TOKEN_AUDIENCE=rag-widget
WIDGET_TOKEN_CLOCK_SKEW_SECONDS=30
# Direct localhost testing uses a short-lived server-signed identity. Never enable this in production or public previews.
LOCAL_DEMO_WIDGET_ENABLED=true
LOCAL_DEMO_WIDGET_EXTERNAL_USER_ID=local-demo-user
LOCAL_DEMO_WIDGET_DISPLAY_NAME=کاربر آزمایشی محلی
LOCAL_DEMO_WIDGET_TOKEN_TTL_SECONDS=300
CORS_ALLOWED_ORIGINS=

# Ingestion limits
MAX_UPLOAD_BYTES=10485760
MAX_EXTRACTED_CHARS=1000000
MAX_PDF_PAGES=200
MAX_CRAWL_PAGES=5
MAX_CRAWL_DEPTH=1
MAX_CRAWL_RESPONSE_BYTES=2097152
CRAWL_TIMEOUT_SECONDS=15
